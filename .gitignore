# Jupyter
.ipynb_checkpoints/

# Project data (DVC-tracked).
# DVC creates per-directory .gitignore files for actual data;
# we keep .dvc pointer files git-tracked.
/data/raw/*
!/data/raw/*.dvc
!/data/raw/.gitignore
/data/processed/*
!/data/processed/*.dvc
!/data/processed/.gitignore
/data/final/*
!/data/final/.gitkeep
!/data/final/*.dvc
!/data/final/.gitignore
/models/*
!/models/*.dvc
!/models/.gitignore
*.dvc.tmp

# DVC writes metrics.csv (cache: false) on every `dvc repro` — XGBoost has
# cross-platform float nondeterminism, so committing it produces noisy diffs.
# CI publishes metrics via the deploy gate; locally treat it as transient.
/metrics.csv

# MLflow
mlruns/
mlartifacts/

# Bento
bentoml/
*.bento

# Hydra
outputs/
multirun/

# Phase 9 drift reports — regenerated by `python -m monitoring.drift_report`
# (or CI). Treat like /metrics.csv: transient, locally regenerable, not
# part of the source-of-truth.
/reports/*
!/reports/.gitkeep

# Phase 10 pdoc output — regenerated by `make docs`. Transient build artifact
# (like /reports and /metrics.csv); publish via GitHub Pages later, don't commit.
/docs/*
!/docs/.gitkeep

# Misc
*.log
